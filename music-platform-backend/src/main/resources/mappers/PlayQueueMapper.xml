<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.music.platform.mapper.PlayQueueMapper">

    <resultMap id="MusicMap" type="com.music.platform.domain.Music">
        <id column="m_id" property="id"/>
        <result column="title" property="title"/>
        <result column="artist" property="artist"/>
        <result column="album" property="album"/>
        <result column="mood_tag" property="moodTag" javaType="com.music.platform.domain.Mood"/>
        <result column="duration_ms" property="durationMs"/>
        <result column="music_path" property="musicPath"/>
        <result column="cover_path" property="coverPath"/>
        <result column="lyric_path" property="lyricPath"/>
        <result column="play_count" property="playCount"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <resultMap id="QueueItemMap" type="com.music.platform.domain.PlayQueueItem">
        <id column="queue_id" property="id"/>
        <result column="queue_position" property="position"/>
        <association property="music" resultMap="MusicMap"/>
    </resultMap>

    <select id="listWithMusic" resultMap="QueueItemMap">
        SELECT q.id            AS queue_id,
               q.position      AS queue_position,
               m.id            AS m_id,
               m.title,
               m.artist,
               m.album,
               m.mood_tag,
               m.duration_ms,
               m.music_path,
               m.cover_path,
               m.lyric_path,
               m.play_count,
               m.created_at,
               m.updated_at
        FROM user_play_queue q
                 JOIN music m ON m.id = q.music_id
        WHERE q.user_id = #{userId}
        ORDER BY q.position ASC, q.id ASC
    </select>

    <select id="maxPosition" resultType="int">
        SELECT COALESCE(MAX(position), -1)
        FROM user_play_queue
        WHERE user_id = #{userId}
    </select>

    <insert id="insert">
        INSERT INTO user_play_queue(user_id, music_id, position)
        VALUES (#{userId}, #{musicId}, #{position})
    </insert>

    <delete id="deleteByIdAndUser">
        DELETE
        FROM user_play_queue
        WHERE id = #{id}
          AND user_id = #{userId}
    </delete>

    <delete id="deleteAllByUser">
        DELETE
        FROM user_play_queue
        WHERE user_id = #{userId}
    </delete>

    <update id="updatePosition">
        UPDATE user_play_queue
        SET position = #{position}
        WHERE id = #{id}
          AND user_id = #{userId}
    </update>

    <select id="countByUser" resultType="int">
        SELECT COUNT(1)
        FROM user_play_queue
        WHERE user_id = #{userId}
    </select>

    <select id="existsItem" resultType="int">
        SELECT COUNT(1)
        FROM user_play_queue
        WHERE user_id = #{userId}
          AND id = #{id}
    </select>

</mapper>
